# CarbonTrack Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# ────────────────────────────────────────────────────────────
# OpenAI API Key (optional — enables AI-powered insights)
#
# Server-side only. Never exposed to the browser bundle.
# Set this when deploying to Vercel/Netlify or running locally
# with `npm run dev` (the Vite dev server proxies /api routes).
#
# To get a key: https://platform.openai.com/api-keys
# Scope it to gpt-4o-mini / completions only.
# ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
